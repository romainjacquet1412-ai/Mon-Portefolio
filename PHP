    <style>
        :root {
            --primary: #4361ee;
            --primary-light: #4895ef;
            --secondary: #4cc9f0;
            --accent: #f72585;
            --dark: #0b132b;
            --text-main: #2b2d42;
            --text-light: #8d99ae;
            --bg-light: #f8f9fa;
            --gradient-main: linear-gradient(135deg, #4361ee 0%, #4cc9f0 100%);
            --glass-bg: rgba(255, 255, 255, 0.95);
            --shadow-soft: 0 10px 40px rgba(0, 0, 0, 0.08);
        }
        
        body {
            font-family: 'Outfit', sans-serif;
            color: var(--text-main);
            background-color: #fcfcfc;
            overflow-x: hidden;
            line-height: 1.7;
        }
        /* --- Animations --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }
        /* --- Navbar --- */
        .navbar {
            background: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            padding: 15px 0;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
            transition: all 0.3s ease;
        }
        
        .navbar-brand {
            font-weight: 800;
            background: var(--gradient-main);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.5rem;
        }
        
        .nav-link {
            color: var(--text-main) !important;
            font-weight: 500;
            padding: 8px 18px !important;
            border-radius: 50px;
            transition: all 0.3s;
            margin: 0 2px;
        }
        
        .nav-link:hover, .nav-link.active {
            color: var(--primary) !important;
            background-color: rgba(67, 97, 238, 0.08);
        }
        /* --- Hero --- */
        .hero {
            padding: 160px 0 100px;
            background: radial-gradient(circle at top right, rgba(76, 201, 240, 0.15), transparent 40%),
                        radial-gradient(circle at bottom left, rgba(67, 97, 238, 0.15), transparent 40%);
            position: relative;
            overflow: hidden;
        }
        
        .hero h1 {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 20px;
            line-height: 1.1;
        }
        
        .hero-img {
            width: 350px;
            height: 350px;
            object-fit: cover;
            border-radius: 40px; /* Squircle */
            box-shadow: 20px 20px 60px rgba(0,0,0,0.1), -20px -20px 60px rgba(255,255,255,0.8);
            animation: float 6s ease-in-out infinite;
        }
        /* --- Buttons --- */
        .btn-modern {
            background: var(--gradient-main);
            color: white;
            border: none;
            padding: 12px 35px;
            border-radius: 50px;
            font-weight: 600;
            box-shadow: 0 10px 20px rgba(67, 97, 238, 0.3);
            transition: all 0.3s;
        }
        .btn-modern:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(67, 97, 238, 0.4);
            color: white;
        }
        .btn-outline-modern {
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 10px 30px;
            border-radius: 50px;
            font-weight: 600;
            background: transparent;
            transition: all 0.3s;
        }
        .btn-outline-modern:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-3px);
        }
        /* --- Cards Global --- */
        .card-glass {
            background: white;
            border-radius: 24px;
            padding: 30px;
            border: 1px solid rgba(0,0,0,0.03);
            box-shadow: var(--shadow-soft);
            transition: all 0.3s ease;
            height: 100%;
        }
        .card-glass:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
        }
        /* --- Section Titles --- */
        .section-title {
            text-align: center;
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 70px;
            color: var(--dark);
            position: relative;
        }
        .section-title::after {
            content: '';
            display: block;
            width: 60px;
            height: 5px;
            background: var(--gradient-main);
            margin: 15px auto 0;
            border-radius: 10px;
        }
        /* Subtitles for Semesters */
        .semester-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .semester-title::after {
            content: '';
            flex-grow: 1;
            height: 2px;
            background: #e9ecef;
            border-radius: 2px;
        }
        section { padding: 100px 0; }
        /* --- Diplomas --- */
        .diploma-icon {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 20px;
            background: rgba(67, 97, 238, 0.1);
            width: 80px;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 20px;
            margin-left: auto;
            margin-right: auto;
        }
        /* --- Skills --- */
        .skill-bar {
            height: 10px;
            background: #e9ecef;
            border-radius: 10px;
            overflow: hidden;
            margin-top: 10px;
        }
        .skill-progress {
            height: 100%;
            background: var(--gradient-main);
            border-radius: 10px;
            width: 0;
            transition: width 1.5s ease-in-out;
        }
        /* --- Experience Timeline --- */
        .timeline {
            position: relative;
            max-width: 1000px;
            margin: 0 auto;
        }
        .timeline::after {
            content: '';
            position: absolute;
            width: 4px;
            background-color: #e9ecef;
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -2px;
            border-radius: 2px;
        }
        .timeline-item {
            padding: 10px 40px;
            position: relative;
            width: 50%;
        }
        .timeline-item::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            right: -10px;
            background-color: white;
            border: 4px solid var(--primary);
            border-radius: 50%;
            top: 20px;
            z-index: 1;
        }
        .left { left: 0; }
        .right { left: 50%; }
        .right::after { left: -10px; }
        
        .timeline-content {
            padding: 25px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            border-left: 5px solid var(--primary);
            transition: 0.3s;
        }
        .timeline-content:hover { transform: translateX(5px); }
        /* --- Rapports / Accordion --- */
        .teacher-section { margin-bottom: 20px; }
        
        .teacher-header {
            display: flex;
            align-items: center;
            padding: 20px 30px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            cursor: pointer;
            transition: all 0.3s;
            border: 1px solid transparent;
        }
        .teacher-header:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border-color: var(--primary);
        }
        .teacher-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: #f1f3f5;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: var(--text-light);
            margin-right: 20px;
        }
        
        .documents-container { display: none; margin-top: 30px; margin-bottom: 40px;}
        
        .document-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: 0.3s;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        .document-card:hover { transform: translateY(-5px); }
        .document-img { height: 160px; object-fit: cover; width: 100%; }
        .document-content { padding: 20px; flex-grow: 1; display: flex; flex-direction: column; }
        
        .btn-download-sm {
            width: 100%;
            background: var(--dark);
            color: white;
            border: none;
            padding: 8px;
            border-radius: 12px;
            font-size: 0.85rem;
            margin-top: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
            transition: 0.3s;
        }
        .btn-download-sm:hover { background: var(--primary); color: white; }
        /* --- Veille --- */
        .veille-table {
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-soft);
            background: white;
        }
        .veille-table th { background: var(--dark); color: white; padding: 20px; font-weight: 500; border: none; }
        .veille-table td { padding: 20px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
        /* --- Footer --- */
        footer {
            background: var(--dark);
            color: white;
            padding: 60px 0 30px;
        }
        .social-icon-btn {
            display: inline-flex;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            color: white;
            align-items: center;
            justify-content: center;
            margin: 0 10px;
            transition: 0.3s;
            text-decoration: none;
        }
        .social-icon-btn:hover { background: var(--primary); transform: translateY(-5px); }
        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            .timeline::after { left: 31px; }
            .timeline-item { width: 100%; padding-left: 70px; padding-right: 25px; }
            .timeline-item::after { left: 21px; }
            .left::after, .right::after { left: 21px; }
            .right { left: 0; }
            .teacher-header { flex-direction: column; text-align: center; gap: 15px; }
            .teacher-avatar { margin-right: 0; }
        }
    </style>
</head>
