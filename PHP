    <script>
        // Scroll Reveal
        function reveal() {
            var reveals = document.querySelectorAll(".reveal");
            for (var i = 0; i < reveals.length; i++) {
                var windowHeight = window.innerHeight;
                var elementTop = reveals[i].getBoundingClientRect().top;
                if (elementTop < windowHeight - 100) {
                    reveals[i].classList.add("active");
                }
            }
        }
        window.addEventListener("scroll", reveal);
        reveal(); // Init
        
        // Skill Bars
        window.addEventListener('scroll', function() {
            document.querySelectorAll('.skill-progress').forEach(bar => {
                const rect = bar.getBoundingClientRect();
                if(rect.top < window.innerHeight) {
                    bar.style.width = bar.getAttribute('data-width');
                }
            });
        });
        
        // Toggle Documents
        function toggleDocuments(id) {
            const el = document.getElementById(id);
            if (el.style.display === 'block') {
                el.style.display = 'none';
            } else {
                el.style.display = 'block';
                el.style.animation = 'fadeInUp 0.5s ease';
            }
        }
        
        // CV Download
        document.getElementById('downloadCV').addEventListener('click', function() {
            const link = document.createElement('a');
            link.href = 'CV Romain Jacquet.pdf'; 
            link.download = 'CV Romain Jacquet.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        });
        
        // Form Submit (if present)
        let contactForm = document.getElementById('contactForm');
        if(contactForm) {
            contactForm.addEventListener('submit', function(e) {
                e.preventDefault();
                alert('Merci ! Votre message a été envoyé.');
                this.reset();
            });
        }

        // Téléchargement de tous les PDFs en ZIP
        document.getElementById('downloadAllPdfs').addEventListener('click', async function() {
            const btn = this;
            const originalText = btn.innerHTML;
            
            // Changement visuel du bouton pour faire patienter l'utilisateur
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Création du ZIP en cours...';
            btn.disabled = true;

            try {
                const zip = new JSZip();
                const sections = document.querySelectorAll('.teacher-section');
                const fetchPromises = [];

                sections.forEach(section => {
                    // Récupérer le nom du professeur/section pour créer un dossier
                    const titleElement = section.querySelector('h4');
                    if (!titleElement) return;
                    
                    // Nettoyer le nom du dossier pour éviter les caractères invalides
                    const folderName = titleElement.innerText.trim().replace(/[^a-zA-Z0-9 -]/g, ""); 
                    const folder = zip.folder(folderName);

                    // Cibler uniquement les liens qui finissent par .pdf
                    const pdfLinks = section.querySelectorAll('a[href$=".pdf"]');
                    
                    pdfLinks.forEach(link => {
                        const url = link.getAttribute('href');
                        // Utiliser l'attribut download comme nom, ou le nom du fichier dans l'URL
                        let filename = link.getAttribute('download') || url.split('/').pop();
                        if (!filename.toLowerCase().endsWith('.pdf')) filename += '.pdf';

                        // Télécharger le fichier et l'ajouter au dossier ZIP
                        const promise = fetch(url)
                            .then(response => {
                                if (!response.ok) throw new Error(`Erreur HTTP: ${response.status}`);
                                return response.blob();
                            })
                            .then(blob => {
                                folder.file(filename, blob);
                            })
                            .catch(e => console.warn(`Impossible de télécharger ${url}:`, e));
                        
                        fetchPromises.push(promise);
                    });
                });

                // Attendre que tous les téléchargements soient terminés
                await Promise.all(fetchPromises);
                
                // Générer le ZIP et déclencher le téléchargement
                const content = await zip.generateAsync({ type: "blob" });
                saveAs(content, "Comptes_Rendus_Romain_Jacquet.zip");

            } catch (error) {
                console.error("Erreur lors de la création du ZIP :", error);
                alert("Une erreur est survenue lors de la création du fichier ZIP.");
            } finally {
                // Remettre le bouton à son état normal
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });
    </script>
